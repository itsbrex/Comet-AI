{
  "name": "Comet-AI",
  "version": "0.2.7",
  "private": true,
  "description": "Comet-AI Browser - A high-performance, intelligence-driven browsing workspace with local LLM support and advanced productivity features.",
  "author": "Latestinssan",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently \"npm:electron-dev\" \"wait-on http://localhost:3003 && electron .\"",
    "electron-dev": "next dev -p 3003",
    "electron-start": "electron .",
    "build": "next build",
    "start": "npx serve@latest out",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "predev": "npx tsc src/lib/P2PFileSyncService.ts src/lib/WiFiSyncService.ts src/lib/modelRegistry.ts src/lib/CloudSyncService.ts src/types/electron.d.ts --outDir src/lib --module CommonJS --skipLibCheck --esModuleInterop",
    "test:prod": "node test-production.js",
    "prebuild-electron": "node verify-build.js",
    "build-macos-helper": "node scripts/build-macos-device-unlock-helper.js",
    "build-macos-native-panels": "node scripts/build-macos-native-panels.js",
    "build-electron": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win --x64",
    "electron:build:mac": "npm run build-macos-helper && npm run build-macos-native-panels && npm run build && electron-builder --mac",
    "electron:build:linux": "npm run build && electron-builder --linux",
    "dist:win": "npm run build && electron-builder --win --x64",
    "dist:mac": "npm run build-macos-helper && npm run build-macos-native-panels && npm run build && electron-builder --mac --publish never",
    "dist:linux": "npm run build && electron-builder --linux",
    "rebuild": "electron-rebuild",
    "rebuild:native": "electron-rebuild -f -w robotjs && electron-rebuild -f -w sharp",
    "postinstall": "electron-builder install-app-deps",
    "check-dups": "node check_dups.js",
    "service": "electron src/service/service-main.js",
    "service:install": "node scripts/install-service.js"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.63",
    "@ai-sdk/google": "^3.0.52",
    "@ai-sdk/groq": "^3.0.31",
    "@ai-sdk/mcp": "^1.0.30",
    "@ai-sdk/openai": "^3.0.47",
    "@ai-sdk/xai": "^3.0.72",
    "@ghostery/adblocker-electron": "^2.14.1",
    "@googleapis/gmail": "^16.1.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@tensorflow/tfjs": "^4.22.0",
    "ai": "^6.0.134",
    "ai-sdk-ollama": "^3.8.0",
    "autoprefixer": "^10.4.23",
    "body-parser": "^2.2.2",
    "chart.js": "^4.5.1",
    "cross-fetch": "^4.1.0",
    "docx": "^8.5.0",
    "electron-context-menu": "^4.1.1",
    "electron-log": "^5.4.3",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "es-errors": "^1.3.0",
    "express": "^5.2.1",
    "firebase": "^12.7.0",
    "framer-motion": "^12.23.26",
    "googleapis": "^171.4.0",
    "jimp": "^1.6.0",
    "lucide-react": "^0.562.0",
    "mermaid": "^11.9.0",
    "mysql2": "^3.11.5",
    "nanoid": "^3.3.11",
    "node-cron": "^3.0.3",
    "object-inspect": "^1.13.3",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "pdfmake": "^0.2.18",
    "pptxgenjs": "^3.12.0",
    "qrcode": "^1.5.4",
    "qs": "^6.13.1",
    "robotjs": "^0.6.0",
    "screenshot-desktop": "^1.15.3",
    "sharp": "^0.34.5",
    "side-channel": "^1.1.0",
    "tesseract.js": "^7.0.0",
    "wait-on": "^9.0.3",
    "ws": "^8.18.0",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "@cherrystudio/mac-system-ocr": "^0.2.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@eslint/compat": "^2.0.1",
    "@jest/globals": "^30.3.0",
    "@next/eslint-plugin-next": "^16.1.4",
    "@tailwindcss/postcss": "^4",
    "@types/chrome": "^0.1.36",
    "@types/node": "^20.19.33",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/tesseract.js": "^0.0.2",
    "@types/ws": "^8.18.1",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^13.24.0",
    "jest": "^30.3.0",
    "katex": "^0.16.27",
    "mocha": "^11.7.5",
    "next": "^16.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^9.2.1",
    "react-pdftotext": "^1.3.4",
    "react-syntax-highlighter": "^16.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8.53.1",
    "zustand": "^5.0.9"
  },
  "packageManager": "npm@11.5.1",
  "build": {
    "appId": "com.latestinssan.cometbrowser",
    "productName": "Comet-AI",
    "copyright": "Copyright © 2026 Latestinssan",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/robotjs/**/*",
      "**/node_modules/sharp/**/*"
    ],
    "files": [
      "out/**/*",
      "main.js",
      "preload.js",
      "view_preload.js",
      "src/lib/**/*",
      "src/service/**/*",
      "src/automation/**/*",
      "src/core/**/*",
      "assets/**/*",
      "bin/**/*",
      "package.json"
    ],
    "npmRebuild": true,
    "nodeGypRebuild": false,
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "license": "LICENSE.txt",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Comet-AI"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "appx": {
      "identityName": "Latestinssan.Comet-AI",
      "publisher": "CN=CF2DF47B-A710-4E1D-8C29-FC648FFA1CAE",
      "publisherDisplayName": "Latestinssan",
      "applicationId": "Comet-AI"
    },
    "mac": {
      "icon": "assets/icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Network;WebBrowser"
    },
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "protocols": [
      {
        "name": "Comet AI Browser Auth",
        "schemes": [
          "comet-browser"
        ]
      },
      {
        "name": "HTTP Web Links",
        "schemes": [
          "http",
          "https"
        ]
      }
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
